{
  "$schema": "https://docs.anthropic.com/claude-code/settings.schema.json",
  "_comment": "Copy relevant sections to your .claude/settings.json",

  "mcpServers": {
    "memrepo": {
      "command": "node",
      "args": ["/path/to/memrepo/dist/server.js"],
      "env": {
        "MEMREPO_ROOT": "/path/to/your/project"
      }
    }
  },

  "_comment2": "Optional: auto-update memory after edits",
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "echo '[memrepo] Consider running /after-edit to update memory'"
      }
    ]
  }
}
